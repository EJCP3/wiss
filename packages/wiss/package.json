{
  "name": "wissfort",
  "version": "0.3.0",
  "description": "Librería de notificaciones toast minimalista, personalizable y bonita",
  "keywords": [
    "toast",
    "notification",
    "alert",
    "vanilla",
    "tailwind"
  ],
  "author": "EJCP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EJCP3/wiss.git"
  },
  "homepage": "https://wiss-docs.vercel.app/",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/core.es.js",
      "require": "./dist/core.cjs.js",
      "types": "./dist/core/index.d.ts"
    },
    "./vanilla": {
      "import": "./dist/vanilla.es.js",
      "require": "./dist/vanilla.cjs.js",
      "types": "./dist/vanilla/index.d.ts"
    },
    "./island": {
      "import": "./dist/island.es.js",
      "require": "./dist/island.cjs.js",
      "types": "./dist/styles/island.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./react": {
      "import": "./dist/react.es.js",
      "require": "./dist/react.cjs.js",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.es.js",
      "require": "./dist/vue.cjs.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte.es.js",
      "require": "./dist/svelte.cjs.js",
      "types": "./dist/svelte/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "playground": "vite --open /playground/sileo-test.html"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "svelte": ">=3",
    "tailwindcss": ">=3",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.3",
    "vue": "^3.5.40"
  },
  "dependencies": {
    "cuelume": "^0.1.0"
  }
}
