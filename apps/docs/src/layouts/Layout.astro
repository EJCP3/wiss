---
import '@fontsource/ibm-plex-sans';
import '@fontsource/ibm-plex-mono';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "wissfort - An opinionated toast component" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 antialiased min-h-screen selection:bg-zinc-200 dark:selection:bg-zinc-800 transition-colors duration-300">
    <slot />
  </body>
</html>
