---
import Layout from '../layouts/Layout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import PreviewBlock from '../components/PreviewBlock.astro';
---

<Layout title="wissfort">
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md transition-colors duration-300">
    <div class="font-bold text-lg tracking-tight">wissfort</div>
    <div class="flex items-center gap-6 text-sm font-medium text-zinc-500 dark:text-zinc-400">
      <a href="https://github.com/EJCP3/wissfort" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">GitHub</a>
      <a href="https://www.npmjs.com/package/wissfort" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">NPM</a>
      <a href="#docs" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">Docs</a>

      
      <div class="w-px h-4 bg-zinc-300 dark:bg-zinc-700"></div>
      
      <button id="lang-toggle" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors font-medium">ES</button>
      
      <button id="theme-toggle" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors flex items-center" title="Cambiar Tema">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button id="format-toggle" class="hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors font-mono text-xs bg-zinc-100 dark:bg-zinc-800 px-2.5 py-1 rounded-md border border-zinc-200 dark:border-zinc-700" title="Cambiar Formato">
        classic
      </button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="min-h-screen flex flex-col items-center justify-center relative pt-24 pb-12">
    <div class="text-center space-y-6 max-w-2xl px-4">
      <h1 class="text-6xl md:text-[5rem] font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
        wissfort<span class="text-zinc-300">.</span>
      </h1>
      <p class="text-zinc-500 text-lg leading-relaxed max-w-lg mx-auto">
        An opinionated toast component for modern apps. SVG morphing, spring physics, and a minimal API — beautiful by default.
      </p>
      
      <div class="flex justify-center pt-2">
        <button class="copy-button group" onclick="navigator.clipboard.writeText('pnpm install wissfort')">
          <span class="text-zinc-400">$</span>
          <span>pnpm install wissfort</span>
          <svg class="w-4 h-4 text-zinc-400 group-hover:text-zinc-600 dark:text-zinc-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
        </button>
      </div>

      <div class="flex justify-center gap-6 pt-2 text-sm font-medium text-zinc-500">
        <a href="#playground" class="hover:text-zinc-900 dark:text-zinc-100 transition-colors">Playground &rarr;</a>
        <a href="#docs" class="text-zinc-900 dark:text-zinc-100 font-bold hover:underline decoration-zinc-300 underline-offset-4">Documentation</a>
      </div>
    </div>

    <!-- Playground Buttons (Try It) positioned at the bottom of the hero -->
    <div id="playground" class="absolute bottom-12 left-0 right-0 flex flex-col items-center gap-5">
      <span class="text-xs font-bold tracking-[0.2em] text-zinc-300 uppercase">Try It</span>
      <div class="flex flex-wrap justify-center gap-2 px-4">
        <button class="toast-btn">Success</button>
        <button class="toast-btn">Error</button>
        <button class="toast-btn">Warning</button>
        <button class="toast-btn">Info</button>
        <button class="toast-btn">Action</button>
        <button class="toast-btn">Promise</button>
      </div>
    </div>
  </section>

  <!-- Documentation Section -->
  <section id="docs" class="bg-[#f8faff] dark:bg-zinc-950 min-h-screen py-24 transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-8 flex gap-16 relative">
      
      <!-- Sticky Sidebar -->
      <aside class="w-48 shrink-0 hidden md:block">
        <div class="sticky top-12 space-y-6">
          <div class="flex items-center gap-2 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
            En esta página
          </div>
          <nav class="flex flex-col gap-2.5 text-sm text-zinc-500 dark:text-zinc-400 toc-nav">
            <a href="#introduccion" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Introducción
            </a>
            <a href="#instalacion" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Instalación
            </a>
            <a href="#uso-basico" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Uso básico
            </a>
            <a href="#opciones" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">Opciones por Toast</span>
            </a>
            <a href="#historial" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">Historial</span>
            </a>
            <a href="#configuracion" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Configuración Global
            </a>
            <a href="#uso-astro" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Uso en Astro
            </a>
            <a href="#temas" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Integración UI
            </a>
            <a href="#tailwind" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">Tailwind CSS</span>
            </a>
            <a href="#react" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">React</span>
            </a>
            <a href="#vue" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">Vue</span>
            </a>
            <a href="#svelte" data-sub class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors pl-3">
              <span class="toc-line w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-4 group-hover:bg-zinc-400"></span>
              <span class="text-[13px] opacity-80">Svelte</span>
            </a>
            <a href="#roadmap" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Roadmap
            </a>
            <a href="#creditos" class="toc-link group flex items-center gap-3 hover:text-zinc-900 dark:text-zinc-100 dark:hover:text-zinc-100 transition-colors">
              <span class="toc-line w-4 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:w-6 group-hover:bg-zinc-400"></span>
              Créditos
            </a>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <article class="flex-1 max-w-2xl prose prose-zinc prose-a:text-zinc-900 dark:text-zinc-100 pb-32">
        <h2 id="introduccion" class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-6">Introducción</h2>
        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">
          Librería de notificaciones toast headless y sin dependencias de runtime. El núcleo (wiss) es un "cerebro" de TypeScript puro —estado, cola, timers— que no sabe nada del DOM ni de ningún framework. La capa visual es intercambiable: por defecto trae sus propios temas (light y dark) o puedes optar por heredar el tema de tu proyecto vía daisyUI o shadcn/ui para que se adapte a tu diseño actual.
        </p>
        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">
          Esta fase incluye un único adaptador, Vanilla JS, que también sirve para Astro.
        </p>

        <h2 id="instalacion" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 mt-12">Instalación</h2>
        <CodeBlock lang="bash" code="pnpm add wissfort" />
        <h2 id="sonido-e-interacciones" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 mt-12">Sonido e Interacciones</h2>
        
        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">
          <strong>wissfort</strong> utiliza con gran énfasis <a href="https://cuelume-site.pages.dev/" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 underline font-semibold">cuelume</a> para su sistema de sonido. Esta increíble librería sintetiza el audio en vivo sin usar pesados archivos <code>.mp3</code>, manteniendo el impacto en el rendimiento <strong>completamente nulo</strong> (menos de 40 KB descomprimida).
        </p>

        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">
          El sonido viene activado por defecto, pero si deseas desactivarlo globalmente, puedes hacerlo en la configuración:
        </p>
        <CodeBlock lang="js" code={`import { toaster } from 'wissfort';\n\ntoaster({ sound: false });`} />

        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6 mt-6">
          También puedes <strong>personalizar el sonido</strong> que se reproduce al lanzar una notificación individual pasando el nombre del sonido en la opción <code>sound</code>:
        </p>
        <CodeBlock lang="js" code={`toast.info('Notificación con sonido especial', { sound: 'sparkle' });`} />

        <div class="mt-8 mb-6 p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-[#121214]">
          <h3 class="font-bold text-zinc-900 dark:text-zinc-100 mb-2">Sonidos por defecto:</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">
            Cada tipo de toast trae un sonido de <code>cuelume</code> preasignado que encaja perfectamente con su intención:
          </p>
          <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 text-sm text-zinc-600 dark:text-zinc-400">
            <li><strong>success:</strong> <code>success</code></li>
            <li><strong>error:</strong> <code>press</code></li>
            <li><strong>warning:</strong> <code>chime</code></li>
            <li><strong>info:</strong> <code>droplet</code></li>
            <li><strong>loading:</strong> <code>bloom</code></li>
          </ul>
        </div>

        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Catálogo de Sonidos Interactivo</h3>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-6">
          Explora todos los sonidos disponibles haciendo clic en los siguientes botones. Cada uno ejecutará un toast de información pero con su respectivo sonido personalizado.
        </p>

        <PreviewBlock id="sound-catalog" lang="js" code={`import { toast } from 'wissfort';

// Prueba cualquier sonido personalizado
toast.info('Chime sonando', { sound: 'chime' });
toast.info('Mensaje discreto', { sound: 'whisper' });
toast.info('Error mecánico', { sound: 'toggle' });`}>
          <div slot="preview" class="flex flex-wrap justify-center gap-2 px-4 max-w-2xl mx-auto">
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="chime">chime</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="sparkle">sparkle</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="droplet">droplet</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="bloom">bloom</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="whisper">whisper</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="tick">tick</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="press">press</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="release">release</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="toggle">toggle</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="success">success</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="error">error</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="page">page</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="loading">loading</button>
            <button class="sound-demo-btn px-4 py-2 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-600 dark:text-zinc-300 transition-colors" data-sound="ready">ready</button>
          </div>
        </PreviewBlock>

        <h2 id="uso-basico" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 mt-12">Uso básico</h2>
        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">Importa la función <code>toast</code> para lanzar notificaciones de diferentes tipos.</p>
        
        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Notificaciones Simples</h3>
        <PreviewBlock id="toast-simple" lang="js" code={`import { toast } from 'wissfort';

toast.success('Usuario creado');
toast.error('Algo salió mal');
toast.warning('Revisa este campo');
toast.info('Nueva actualización disponible');`}>
          <div slot="preview" class="flex flex-wrap justify-center gap-3">
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Success</button>
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Error</button>
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Warning</button>
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Info</button>
          </div>
        </PreviewBlock>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-4 text-center">💡 Puedes editar el código de cualquier ejemplo en su pestaña "Code" y ejecutarlo en vivo.</p>

        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Toast con Acción (Action)</h3>
        <PreviewBlock id="toast-action" lang="js" code={`import { toast } from 'wissfort';

toast.show('Elemento eliminado', { 
  action: { 
    label: 'Deshacer', 
    onClick: () => console.log('Acción deshecha') 
  } 
});`}>
          <div slot="preview" class="flex justify-center">
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Action</button>
          </div>
        </PreviewBlock>

        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Toast con Promesa (Promise)</h3>
        <PreviewBlock id="toast-promise" lang="js" code={`import { toast } from 'wissfort';

toast.promise(
  fetch('/api/users'),
  {
    loading: 'Cargando usuarios...',
    success: 'Usuarios cargados correctamente',
    error: 'Error al cargar usuarios',
  }
);`}>
          <div slot="preview" class="flex justify-center">
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Promise</button>
          </div>
        </PreviewBlock>

        <h2 id="opciones" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 mt-12">Opciones por Toast</h2>
        <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-6">Puedes pasar un objeto de configuración como segundo parámetro a cualquier método para personalizar un toast individual.</p>

        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Toast con Descripción</h3>
        <PreviewBlock id="toast-description" lang="js" code={`import { toast } from 'wissfort';

toast.success('¡Archivo guardado!', {
  description: 'El archivo se guardó correctamente en tu carpeta local.'
});`}>
          <div slot="preview" class="flex justify-center">
            <button class="toast-btn px-5 py-2.5 bg-[#f6f6f7] hover:bg-[#ececed] dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-xl text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300 transition-colors">Description</button>
          </div>
        </PreviewBlock>

        <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-8">Cambio de Icono</h3>
