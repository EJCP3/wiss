---
import { Code } from 'astro:components';

interface Props {
  code: string;
  lang: any;
}

const { code, lang } = Astro.props;
---

<div class="bg-[#f2f5f9] dark:bg-[#1a1a1e] p-4 sm:p-6 rounded-2xl mb-12 border border-[#e2e8f0] dark:border-zinc-800 relative group">
  <button class="absolute top-4 right-4 bg-white/80 hover:bg-white dark:bg-zinc-800/80 dark:hover:bg-zinc-800 text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 rounded-lg p-2 opacity-0 group-hover:opacity-100 transition-opacity border border-zinc-200/50 dark:border-zinc-700 shadow-sm z-10" onclick={`navigator.clipboard.writeText(this.nextElementSibling.textContent)`} aria-label="Copiar código">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
  </button>
  <div class="overflow-x-auto text-[13px] leading-loose font-mono relative">
    <div class="dark:hidden"><Code code={code.trim()} lang={lang} theme="vitesse-light" class="!bg-transparent" /></div>
    <div class="hidden dark:block"><Code code={code.trim()} lang={lang} theme="vitesse-dark" class="!bg-transparent" /></div>
  </div>
</div>
